# ════════════════════════════════════════════════════════════════════════════
# CivicShield AI — Backend .env.example
# Copy this file to .env and fill in your values before running locally.
# On Render: set these directly in the Environment tab of the service.
# ════════════════════════════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────────────────────────────
# Set to "production" on Render. Enables strict rate limiting (100 req/15min)
# and hides internal stack traces from error responses.
NODE_ENV=development

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server binds to. Render sets this automatically — do not
# override in production.
PORT=4000

# ── Supabase ─────────────────────────────────────────────────────────────────
# REQUIRED. Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — bypasses Row Level Security. Keep secret. Never expose
# to the frontend.
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anon/public key — used by the auth middleware to verify JWTs from the frontend.
# Found in: Supabase Dashboard → Project Settings → API → anon key
SUPABASE_ANON_KEY=your-anon-key-here

# ── ML Service ───────────────────────────────────────────────────────────────
# REQUIRED. Full URL of the deployed FastAPI ML service.
# Local development: http://127.0.0.1:8000
# Render production: https://your-ml-service.onrender.com
ML_SERVICE_URL=http://127.0.0.1:8000

# ── Error Tracking (Optional) ─────────────────────────────────────────────────
# If absent, Sentry is silently skipped — the backend starts normally without it.
# Found in: sentry.io → Your Project → Settings → Client Keys (DSN)
SENTRY_DSN=

# ── NASA FIRMS — Wildfire Hotspots (Optional) ────────────────────────────────
# Free key from: https://firms.modaps.eosdis.nasa.gov/api/area/
# If absent, the FIRMS poller is skipped. Other data sources still function.
FIRMS_API_KEY=

# ── Notification Channels (All Optional) ─────────────────────────────────────
# All notification channels degrade gracefully — if a key is absent, that
# channel is silently skipped. The server still starts and functions normally.

# Resend — Transactional email alerts
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=

# Telegram Bot — disaster alert messages to a Telegram channel or user
# Create a bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
# The chat ID or channel ID to send auto-alerts to (e.g. -1001234567890)
DEFAULT_TELEGRAM_CHAT_ID=

# Twilio — WhatsApp and SMS alerts
# Found in: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio WhatsApp-enabled number (format: whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=
# Your Twilio SMS number (format: +14155238886). Falls back to TWILIO_WHATSAPP_NUMBER.
TWILIO_SMS_NUMBER=
# Default alert recipients for auto-dispatched India critical events
DEFAULT_WHATSAPP_NUMBER=
DEFAULT_SMS_NUMBER=

# Web Push (VAPID) — browser push notifications
# Generate a VAPID key pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# LibreTranslate — multilingual alert translation (hi, ta, te, bn, gu, mr, pa)
# Self-hosted instance URL. Leave blank to disable multilingual alerts.
# Docs: https://libretranslate.com
LIBRETRANSLATE_URL=

# ── Optional: Upstash Redis ──────────────────────────────────────────────────
# If both keys are set, the cache layer upgrades from node-cache (in-memory)
# to Upstash Redis (persistent, survives restarts). Not required for free tier.
# Found in: https://console.upstash.com → Your Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
