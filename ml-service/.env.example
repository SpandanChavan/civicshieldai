# ════════════════════════════════════════════════════════════════════════════
# CivicShield AI — ML Service .env.example
# Copy this file to .env and fill in your values before running locally.
# On Render: set these directly in the Environment tab of the service.
# ════════════════════════════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────────────────────────────
# Set to "production" on Render.
ENVIRONMENT=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this service.
# Defaults to localhost dev ports if unset — add your LAN IP when testing from
# a phone on the same network (e.g. http://192.168.x.x:3000).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── HuggingFace Inference API (Optional) ─────────────────────────────────────
# Used by the misinformation detector as a secondary NLP signal.
# If absent, the detector falls back to pattern-matching only — still functional.
# Free token from: https://huggingface.co/settings/tokens
# Model used: distilbert-base-uncased-finetuned-sst-2-english
HF_API_TOKEN=

# ── Error Tracking (Optional) ─────────────────────────────────────────────────
# If absent, Sentry is silently skipped.
# Found in: sentry.io → Your Project → Settings → Client Keys (DSN)
SENTRY_DSN=
