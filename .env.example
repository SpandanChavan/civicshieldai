# ====================================================
# CIVICSHIELD AI - .env.example (SAFE TO COMMIT)
# Copy to backend/.env and frontend/.env.local
# Fill in real values - DO NOT commit .env files
# ====================================================

# ── BACKEND (backend/.env) ────────────────────────────
PORT=4000
NODE_ENV=development

# Supabase (free - supabase.com)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY   # backend only! NEVER in frontend

# Disaster Data APIs
FIRMS_API_KEY=YOUR_NASA_FIRMS_KEY
OPENWEATHER_API_KEY=YOUR_OWM_KEY
OPENAQ_API_KEY=YOUR_OPENAQ_KEY
ORS_API_KEY=YOUR_OPENROUTESERVICE_KEY
SENTINEL_HUB_KEY=YOUR_SENTINEL_HUB_KEY

# AI & NLP
HF_API_TOKEN=hf_YOUR_HUGGINGFACE_TOKEN
GEMINI_API_KEY=YOUR_GEMINI_KEY
GOOGLE_TRANSLATE_KEY=YOUR_GOOGLE_TRANSLATE_KEY
FACT_CHECK_API_KEY=YOUR_FACT_CHECK_KEY

# Communication
RESEND_API_KEY=re_YOUR_RESEND_KEY
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TWITTER_BEARER_TOKEN=YOUR_TWITTER_BEARER_TOKEN

# Cache
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# Service URLs (update for production)
ML_SERVICE_URL=http://localhost:8000
LIBRETRANSLATE_URL=http://localhost:5000

# Monitoring
SENTRY_DSN=YOUR_SENTRY_DSN

# ── FRONTEND (frontend/.env.local) ───────────────────
# VITE_ prefix = visible in browser - NEVER put secret keys here!
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_BACKEND_URL=http://localhost:4000
VITE_ML_SERVICE_URL=http://localhost:8000

# ── NO KEY NEEDED - use these URLs directly in code ──
# Open-Meteo:       api.open-meteo.com
# USGS Earthquake:  earthquake.usgs.gov/fdsnws/event/1/query
# GDACS:            gdacs.org/xml/rss.xml
# NASA EONET:       eonet.gsfc.nasa.gov/api/v3/events
# OSM Nominatim:    nominatim.openstreetmap.org
# OSRM Routing:     router.project-osrm.org
# OSM Overpass:     overpass-api.de/api/interpreter
